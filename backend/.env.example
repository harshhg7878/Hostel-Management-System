PORT=5000
MONGO_URI=mongodb://<username>:<password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/<database-name>?ssl=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ALLOWED_ORIGINS=https://your-frontend.example.com
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
